PORT=3000
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/<database-name>
JWT_SECRET=<generate_a_long_random_secret>
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=<generate_a_long_random_refresh_secret>
JWT_REFRESH_EXPIRES_IN=15d
ADMIN_EMAIL=admin@advisor.local
ADMIN_USERNAME=admin
ADMIN_PASSWORD=<set_strong_admin_password>
ADMIN_FULL_NAME=System Administrator
CLOUDINARY_CLOUD_NAME=<your_cloudinary_cloud_name>
CLOUDINARY_API_KEY=<your_cloudinary_api_key>
CLOUDINARY_API_SECRET=<your_cloudinary_api_secret>
AI_SERVICE_BASE_URL=http://127.0.0.1:8001/api/v1
AI_SERVICE_TIMEOUT_MS=10000
AI_ANOMALY_ENDPOINT=http://127.0.0.1:8001/api/v1/anomaly/detect
MIN_RECORD_INTERVAL_DAYS=7

# Gemini API (free tier — https://aistudio.google.com/apikey)
# Hỗ trợ 2 key: khi key 1 hết quota/lỗi sẽ tự fallback sang key 2
GEMINI_API_KEY=<your_gemini_api_key_1>
GEMINI_API_KEY_2=<your_gemini_api_key_2>
GEMINI_MODEL=gemini-2.5-flash
